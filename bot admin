async def get_stats_text() -> str:
    users_total = await safe_scalar(f"SELECT COUNT(*) FROM {USERS_TABLE}", default="N/A")
    users_banned = await safe_scalar(f"SELECT COUNT(*) FROM {USERS_TABLE} WHERE COALESCE(is_banned, false) = true", default="N/A")
    groups_total = await safe_scalar(f"SELECT COUNT(*) FROM {GROUPS_TABLE}", default="N/A")
    admins_total = await safe_scalar(f"SELECT COUNT(*) FROM {ADMINS_TABLE} WHERE COALESCE(is_active, true) = true", default="N/A")

    orders_today = await safe_scalar(
        f"SELECT COUNT(*) FROM {ORDERS_TABLE} WHERE created_at::date = CURRENT_DATE",
        default="N/A"
    )
    orders_pending = await safe_scalar(
        f"SELECT COUNT(*) FROM {ORDERS_TABLE} WHERE LOWER(COALESCE(status, '')) IN ('pending','waiting','new')",
        default="N/A"
    )

    tx_today = await safe_scalar(
        f"SELECT COUNT(*) FROM {TX_TABLE} WHERE created_at::date = CURRENT_DATE",
        default="N/A"
    )
    tx_failed = await safe_scalar(
        f"SELECT COUNT(*) FROM {TX_TABLE} WHERE LOWER(COALESCE(status, '')) IN ('failed','error','rejected')",
        default="N/A"
    )

    return (
        "📊 <b>ADMIN STATS</b>\n\n"
        f"👤 Users: <b>{users_total}</b>\n"
        f"🚫 Banned users: <b>{users_banned}</b>\n"
        f"👥 Groups: <b>{groups_total}</b>\n"
        f"🛡 Admins: <b>{admins_total}</b>\n\n"
        f"📦 Orders today: <b>{orders_today}</b>\n"
        f"⏳ Pending orders: <b>{orders_pending}</b>\n"
        f"💳 Transactions today: <b>{tx_today}</b>\n"
        f"❌ Failed TX: <b>{tx_failed}</b>\n"
    )


async def get_user_text(telegram_id: int) -> str:
    row = await adb_fetchone(
        f"""
        SELECT id, telegram_id, username, full_name, is_banned, vip_until, created_at
        FROM {USERS_TABLE}
        WHERE telegram_id = %s
        LIMIT 1
        """,
        (telegram_id,)
    )
    if not row:
        return "❌ Không tìm thấy user."

    return (
        "👤 <b>USER INFO</b>\n\n"
        f"ID: <code>{row.get('telegram_id')}</code>\n"
        f"Username: @{row.get('username') or '-'}\n"
        f"Full name: {row.get('full_name') or '-'}\n"
        f"Banned: {row.get('is_banned')}\n"
        f"VIP until: {fmt_dt(row.get('vip_until'))}\n"
        f"Created: {fmt_dt(row.get('created_at'))}\n"
    )


async def list_groups_text(limit: int = 20) -> str:
    rows = await adb_fetchall(
        f"""
        SELECT chat_id, title, active, created_at
        FROM {GROUPS_TABLE}
        ORDER BY created_at DESC NULLS LAST
        LIMIT %s
        """,
        (limit,)
    )
    if not rows:
        return "👥 Không có group."

    lines = ["👥 <b>LATEST GROUPS</b>\n"]
    for i, r in enumerate(rows, 1):
        lines.append(
            f"{i}. <code>{r.get('chat_id')}</code> | {r.get('title') or '-'} | active={r.get('active')}"
        )
    return "\n".join(lines)


async def list_pending_orders_text(limit: int = 15) -> str:
    rows = await adb_fetchall(
        f"""
        SELECT code, user_id, amount, status, created_at
        FROM {ORDERS_TABLE}
        WHERE LOWER(COALESCE(status, '')) IN ('pending','waiting','new')
        ORDER BY created_at ASC NULLS LAST
        LIMIT %s
        """,
        (limit,)
    )
    if not rows:
        return "📦 Không có pending orders."

    lines = ["📦 <b>PENDING ORDERS</b>\n"]
    for i, r in enumerate(rows, 1):
        lines.append(
            f"{i}. <code>{r.get('code')}</code> | user={r.get('user_id')} | amount={fmt_money(r.get('amount'))} | {r.get('status')}"
        )
    return "\n".join(lines)


async def list_admins_text() -> str:
    if not await table_exists(ADMINS_TABLE):
        owners = ", ".join(str(x) for x in sorted(OWNER_IDS)) or "none"
        return f"🛡 Chưa có bảng admins.\nOwner IDs từ .env:\n<code>{owners}</code>"

    rows = await adb_fetchall(
        f"""
        SELECT telegram_id, username, role, is_active, created_at
        FROM {ADMINS_TABLE}
        ORDER BY created_at ASC NULLS LAST
        """
    )
    if not rows:
        return "🛡 Không có admin trong DB."

    lines = ["🛡 <b>ADMINS</b>\n"]
    for r in rows:
        lines.append(
            f"- <code>{r.get('telegram_id')}</code> | @{r.get('username') or '-'} | role={r.get('role')} | active={r.get('is_active')}"
        )
    if OWNER_IDS:
        lines.append("\n👑 Owners từ .env: " + ", ".join(str(x) for x in sorted(OWNER_IDS)))
    return "\n".join(lines)


def get_service_status() -> str:
    return run_cmd(f"systemctl status {MANAGED_SERVICE} --no-pager")


def restart_service() -> str:
    return run_cmd(f"systemctl restart {MANAGED_SERVICE} && systemctl status {MANAGED_SERVICE} --no-pager")


def get_service_logs() -> str:
    return run_cmd(f"journalctl -u {MANAGED_SERVICE} -n 40 --no-pager")


def get_webhook_info() -> str:
    if not MAIN_BOT_TOKEN:
        return "BOT_TOKEN không có trong .env"
    return run_cmd(f'curl -s "https://api.telegram.org/bot{MAIN_BOT_TOKEN}/getWebhookInfo"')


