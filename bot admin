@dp.message(Command("addadmin"))
async def cmd_addadmin(message: Message):
    if not await require_role(message, "owner"):
        return

    args = message.text.split()
    if len(args) < 2:
        await message.answer("Dùng: /addadmin <telegram_id> <role>\nVí dụ: /addadmin 123456789 admin")
        return

    if not args[1].isdigit():
        await message.answer("telegram_id không hợp lệ.")
        return

    telegram_id = int(args[1])
    role = args[2].lower().strip() if len(args) >= 3 else "admin"
    if role not in ROLE_RANK:
        role = "admin"

    if not await table_exists(ADMINS_TABLE):
        await message.answer("❌ Chưa có bảng admins trong DB.")
        return

    existing = await adb_fetchone(
        f"SELECT telegram_id FROM {ADMINS_TABLE} WHERE telegram_id = %s",
        (telegram_id,)
    )

    if existing:
        await adb_execute(
            f"""
            UPDATE {ADMINS_TABLE}
            SET role = %s, is_active = true
            WHERE telegram_id = %s
            """,
            (role, telegram_id)
        )
    else:
        await adb_execute(
            f"""
            INSERT INTO {ADMINS_TABLE} (telegram_id, username, role, is_active, created_at)
            VALUES (%s, %s, %s, true, NOW())
            """,
            (telegram_id, None, role)
        )

    await audit_log(message.from_user.id, "add_admin", "admin", telegram_id, f"role={role}")
    await message.answer(f"🛡 Đã add/update admin <code>{telegram_id}</code> role=<b>{role}</b>", parse_mode="HTML")


