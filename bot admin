```python
import os
import asyncio
import subprocess
from datetime import datetime

import psycopg2
from psycopg2.extras import RealDictCursor
from dotenv import load_dotenv

from aiogram import Bot, Dispatcher
from aiogram.filters import Command
from aiogram.types import Message
from aiogram.exceptions import TelegramForbiddenError, TelegramBadRequest

load_dotenv("/root/.env")

# =========================
# ENV
# =========================
ADMIN_BOT_TOKEN = os.getenv("ADMIN_BOT_TOKEN", "").strip()
MAIN_BOT_TOKEN = os.getenv("BOT_TOKEN", "").strip()
DATABASE_URL = os.getenv("DATABASE_URL", "").strip()
OWNER_IDS_RAW = os.getenv("OWNER_IDS", "")
MANAGED_SERVICE = os.getenv("MANAGED_SERVICE", "changjiang-bot").strip()

if not ADMIN_BOT_TOKEN:
    raise RuntimeError("ADMIN_BOT_TOKEN is missing in environment variables")

if not DATABASE_URL:
    raise RuntimeError("DATABASE_URL is missing in environment variables")

OWNER_IDS = set()
for x in OWNER_IDS_RAW.split(","):
    x = x.strip()
    if x.isdigit():
        OWNER_IDS.add(int(x))

# =========================
# TABLE NAMES / ASSUMPTIONS
# Đổi ở đây nếu DB mày khác tên bảng
# =========================
USERS_TABLE = "users"
GROUPS_TABLE = "groups"
ORDERS_TABLE = "orders"
TX_TABLE = "transactions"
ADMINS_TABLE = "admins"
AUDIT_TABLE = "audit_logs"

ROLE_RANK = {
    "mod": 1,
    "admin": 2,
    "owner": 3,
}

admin_bot = Bot(token=ADMIN_BOT_TOKEN)
main_bot = Bot(token=MAIN_BOT_TOKEN) if MAIN_BOT_TOKEN else None
dp = Dispatcher()


# =========================
# DB HELPERS
# =========================
def get_conn():
    return psycopg2.connect(DATABASE_URL)


def db_fetchone(query, params=None):
    with get_conn() as conn:
        with conn.cursor(cursor_factory=RealDictCursor) as cur:
            cur.execute(query, params or ())
            return cur.fetchone()


def db_fetchall(query, params=None):
    with get_conn() as conn:
        with conn.cursor(cursor_factory=RealDictCursor) as cur:
            cur.execute(query, params or ())
            return cur.fetchall()


def db_execute(query, params=None):
    with get_conn() as conn:
        with conn.cursor() as cur:
            cur.execute(query, params or ())
            affected = cur.rowcount
        conn.commit()
        return affected


async def adb_fetchone(query, params=None):
    return await asyncio.to_thread(db_fetchone, query, params)


async def adb_fetchall(query, params=None):
    return await asyncio.to_thread(db_fetchall, query, params)


async def adb_execute(query, params=None):
    return await asyncio.to_thread(db_execute, query, params)


# =========================
# SAFE HELPERS
# =========================
async def table_exists(table_name: str) -> bool:
    query = """
    SELECT EXISTS (
        SELECT 1
        FROM information_schema.tables
        WHERE table_schema = 'public' AND table_name = %s
    ) AS exists;
    """
    row = await adb_fetchone(query, (table_name,))
    return bool(row and row["exists"])


async def safe_scalar(query, params=None, default=None):
    try:
        row = await adb_fetchone(query, params)
        if not row:
            return default
        return list(row.values())[0]
    except Exception:
        return default


async def audit_log(admin_id: int, action: str, target_type: str = None, target_id: str = None, detail: str = None):
    try:
        if not await table_exists(AUDIT_TABLE):
            return
        query = f"""
        INSERT INTO {AUDIT_TABLE}
        (admin_telegram_id, action, target_type, target_id, detail, created_at)
        VALUES (%s, %s, %s, %s, %s, NOW())
        """
        await adb_execute(query, (admin_id, action, target_type, str(target_id) if target_id is not None else None, detail))
    except Exception:
        pass


def run_cmd(cmd: str) -> str:
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=25)
        out = (result.stdout or "") + (result.stderr or "")
        out = out.strip() or "(no output)"
        return out[:3800]
    except Exception as e:
        return f"Command error: {e}"


# =========================
# AUTH
# =========================
async def get_role(user_id: int):
    if user_id in OWNER_IDS:
        return "owner"

    try:
        if not await table_exists(ADMINS_TABLE):
            return None

        row = await adb_fetchone(
            f"""
            SELECT telegram_id, username, role, is_active
            FROM {ADMINS_TABLE}
            WHERE telegram_id = %s
            LIMIT 1
            """,
            (user_id,)
        )
        if not row:
            return None
        if row.get("is_active") is False:
            return None

        role = (row.get("role") or "admin").lower().strip()
        if role not in ROLE_RANK:
            role = "admin"
        return role
    except Exception:
        return None


async def has_role(user_id: int, min_role: str = "mod") -> bool:
    role = await get_role(user_id)
    if not role:
        return False
    return ROLE_RANK.get(role, 0) >= ROLE_RANK.get(min_role, 0)


async def require_role(message: Message, min_role: str = "mod") -> bool:
    ok = await has_role(message.from_user.id, min_role)
    if not ok:
        await message.answer("❌ Không có quyền dùng lệnh này.")
        return False
    return True


# =========================
# FORMATTERS
# =========================
def fmt_dt(x):
    if not x:
        return "-"
    if isinstance(x, datetime):
        return x.strftime("%Y-%m-%d %H:%M:%S")
    return str(x)


def fmt_money(x):
    if x is None:
        return "0"
    try:
        return f"{float(x):,.2f}"
    except Exception:
        return str(x)


