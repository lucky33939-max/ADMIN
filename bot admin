@dp.message(Command("broadcast"))
async def cmd_broadcast(message: Message):
    if not await require_role(message, "admin"):
        return

    if not main_bot:
        await message.answer("❌ BOT_TOKEN chưa có, không thể broadcast bằng bot chính.")
        return

    parts = message.text.split(maxsplit=1)
    if len(parts) < 2:
        await message.answer("Dùng: /broadcast <nội dung>")
        return

    text = parts[1].strip()
    rows = await adb_fetchall(
        f"""
        SELECT telegram_id
        FROM {USERS_TABLE}
        WHERE COALESCE(is_banned, false) = false
        ORDER BY id ASC
        LIMIT 5000
        """
    )

    if not rows:
        await message.answer("Không có user để broadcast.")
        return

    total = len(rows)
    sent = 0
    failed = 0

    await message.answer(f"📢 Bắt đầu broadcast tới {total} user...")

    for row in rows:
        uid = row.get("telegram_id")
        if not uid:
            continue
        try:
            await main_bot.send_message(uid, text)
            sent += 1
        except (TelegramForbiddenError, TelegramBadRequest):
            failed += 1
        except Exception:
            failed += 1
        await asyncio.sleep(0.05)

    await audit_log(message.from_user.id, "broadcast", "users", total, f"sent={sent},failed={failed}")
    await message.answer(
        f"📢 Broadcast xong.\n\n✅ Sent: {sent}\n❌ Failed: {failed}\n👥 Total: {total}"
    )


@dp.message(Command("status"))
async def cmd_status(message: Message):
    if not await require_role(message, "mod"):
        return
    text = get_service_status()
    await message.answer(f"<pre>{text}</pre>", parse_mode="HTML")


@dp.message(Command("restartbot"))
async def cmd_restartbot(message: Message):
    if not await require_role(message, "owner"):
        return
    await message.answer("🔁 Đang restart bot chính...")
    text = restart_service()
    await audit_log(message.from_user.id, "restart_service", "service", MANAGED_SERVICE, "manual restart")
    await message.answer(f"<pre>{text}</pre>", parse_mode="HTML")


@dp.message(Command("logs"))
async def cmd_logs(message: Message):
    if not await require_role(message, "owner"):
        return
    text = get_service_logs()
    await message.answer(f"<pre>{text}</pre>", parse_mode="HTML")


@dp.message(Command("webhook"))
async def cmd_webhook(message: Message):
    if not await require_role(message, "admin"):
        return
    text = get_webhook_info()
    await message.answer(f"<pre>{text}</pre>", parse_mode="HTML")


# =========================
# STARTUP
# =========================
async def notify_owners_startup():
    if not OWNER_IDS:
        return
    text = "🟢 Admin bot đã khởi động."
    for owner_id in OWNER_IDS:
        try:
            await admin_bot.send_message(owner_id, text)
        except Exception:
            pass


async def main():
    print("Admin bot is starting...")
    await notify_owners_startup()
    await dp.start_polling(admin_bot)


if __name__ == "__main__":
    asyncio.run(main())
